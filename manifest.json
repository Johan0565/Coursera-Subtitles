{
  "manifest_version": 3,
  "name": "Coursera Subtitle Extensions",
  "description": "Translate Coursera video subtitles in real time into 31 languages using Google Translate.",
  "version": "0.0.3.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/16.png",
      "32": "images/32.png"
    }
  },
  "icons": {
    "16": "images/16.png",
    "32": "images/32.png",
    "48": "images/48.png",
    "128": "images/128.png"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.coursera.org/*"],
      "js": ["js/content.js"]
    }
  ],
  "permissions": ["tabs", "storage", "activeTab"],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
